{
  "renderMarkdown": true,
  "screenReader": false,
  "theme": "auto",
  "enabledPlugins": {
    "context-engineering@awesome-copilot": true,
    "awesome-copilot@awesome-copilot": true,
    "ponytail@ponytail": true
  },
  "showReasoning": false,
  "footer": {
    "showModelEffort": true,
    "showDirectory": true,
    "showBranch": true,
    "showContextWindow": true,
    "showQuota": true,
    "showAgent": true,
    "showCodeChanges": true
  },
  "effortLevel": "high",
  "colorMode": "github",
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  }
}
